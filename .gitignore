# ============================================
# SECURITY - SECRETS & CREDENTIALS
# ============================================

# Secrets and credentials - NEVER commit these
*.pfx
*.p12
*.key
*.pem
*.crt
*.cer
secrets.json
secrets.yaml
secrets.yml
**/secrets/
.env
.env.*
!.env.example
*.env.local

# User secrets
**/usersecrets/

# Local settings with potential secrets
appsettings.Local.json
appsettings.*.Local.json
local.settings.json

# Kubernetes secrets (unencrypted)
*-secret.yaml
*-secrets.yaml
!*-sealed-secret.yaml

# Terraform state (may contain secrets)
*.tfstate
*.tfstate.*
.terraform/

# Helm values with secrets
values-secrets.yaml
**/charts/**/secrets/

