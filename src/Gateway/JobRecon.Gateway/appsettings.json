{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "JobRecon.Identity",
    "Audience": "JobRecon"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://jobrecon.local"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 200
      },
      {
        "Endpoint": "post:/api/auth/*",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/auth"
          },
          {
            "PathPrefix": "/api/auth"
          }
        ]
      },
      "profile-route": {
        "ClusterId": "profile",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        }
      },
      "jobs-route": {
        "ClusterId": "jobs",
        "Match": {
          "Path": "/api/jobs/{**catch-all}"
        }
      },
      "matching-route": {
        "ClusterId": "matching",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/matching/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "profile": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "jobs": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "matching": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  }
}
