{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5002"
      },
      "Grpc": {
        "Url": "http://*:5012",
        "Protocols": "Http2"
      }
    }
  },
  "Jwt": {
    "Issuer": "JobRecon.Identity",
    "Audience": "JobRecon"
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "jobrecon-cvs",
    "UseSSL": false
  }
}
